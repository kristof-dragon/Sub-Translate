# Host ports exposed by docker-compose.
# Change if 8080 / 8081 / 5800 clash with anything else on the host.
API_PORT=8080
WEB_PORT=8081
GUI_PORT=5800

# Path on the host that contains your MKV files. Mounted into the api
# container (read-only, at /media) and the MKVToolNix GUI container
# (read-write, at /storage). Defaults to ./media next to this file.
# Use an absolute path if your media lives elsewhere.
MEDIA_PATH=./media

# UID/GID the jlesage GUI runs as. Match these to the owner of MEDIA_PATH
# if you plan to save edited files back from the GUI.
UID=1000
GID=1000
